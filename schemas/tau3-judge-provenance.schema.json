{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ses.local/schemas/tau3-judge-provenance.schema.json",
  "title": "SES tau3 Judge Run Provenance",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "selection_id", "blind_run_id", "judge_protocol_version", "prompt_sha256", "provider", "model", "endpoint", "repetition_index", "started_at", "finished_at", "attempts", "attempt_log", "status", "response_sha256", "usage"],
  "properties": {
    "schema_version": {"const": "0.1.0"},
    "selection_id": {"type": "string", "pattern": "^validity-[0-9]{3}$"},
    "blind_run_id": {"type": "string", "pattern": "^tau3-blind-[0-9a-f]{16}$"},
    "judge_protocol_version": {"const": "tau3-semantic-judge-v0.5.0"},
    "prompt_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "provider": {"type": "string", "minLength": 1},
    "model": {"type": "string", "minLength": 1},
    "endpoint": {"type": "string", "minLength": 1},
    "repetition_index": {"type": "integer", "minimum": 0},
    "started_at": {"type": "string", "format": "date-time"},
    "finished_at": {"type": "string", "format": "date-time"},
    "attempts": {"type": "integer", "minimum": 1},
    "attempt_log": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["attempt", "status", "failure", "response_id", "response_sha256", "usage"],
        "properties": {
          "attempt": {"type": "integer", "minimum": 1},
          "status": {"type": "string", "enum": ["valid", "invalid_output", "request_error"]},
          "failure": {"type": ["string", "null"]},
          "response_id": {"type": ["string", "null"]},
          "response_sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
          "usage": {"$ref": "#/$defs/usage"}
        }
      }
    },
    "status": {"type": "string", "enum": ["valid", "failed"]},
    "failure": {"type": ["string", "null"]},
    "response_id": {"type": ["string", "null"]},
    "response_sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
    "usage": {"$ref": "#/$defs/usage"}
  },
  "$defs": {
    "usage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["input_tokens", "output_tokens", "cost_usd"],
      "properties": {
        "input_tokens": {"type": ["integer", "null"], "minimum": 0},
        "output_tokens": {"type": ["integer", "null"], "minimum": 0},
        "cost_usd": {"type": ["number", "null"], "minimum": 0}
      }
    }
  }
}
